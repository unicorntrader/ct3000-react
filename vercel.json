{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/sync.js":               { "maxDuration": 60 },
    "api/rebuild.js":            { "maxDuration": 60 },
    "api/debug-flex-xml.js":     { "maxDuration": 60 },
    "api/cron-sync.js":          { "maxDuration": 60 },
    "api/cron-anonymize-churn.js": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/cron-sync",            "schedule": "0 2 * * *" },
    { "path": "/api/cron-anonymize-churn", "schedule": "0 3 * * 0" }
  ]
}
